# GOSU Core Platform - Environment Configuration
# Copy this file to .env and fill in the required values

# ============================================
# Database Configuration
# ============================================
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
DATABASE_URL=postgresql+asyncpg://core_user:CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN@postgres:5432/core_db

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_64_CHARS_MIN
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ============================================
# GOSU API Configuration
# ============================================
GOSU_API_URL=https://apis.gosu.vn
GOSU_APP_ID=UA
GOSU_SECRET=CHANGE_ME_GOSU_API_SECRET

# ============================================
# Application Configuration
# ============================================
APP_NAME=GOSU Core Platform
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development
API_PORT=8000

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# MinIO Configuration
# ============================================
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_SECRET_KEY
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET_NAME=core-files
MINIO_SECURE=false

# ============================================
# SSL Configuration
# ============================================
SSL_VERIFY=true
